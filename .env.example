# =============================================================================
# brand-network-ecosystem — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# All variables marked [REQUIRED] must be set in the Vercel dashboard before
# deploying to production. Variables marked [OPTIONAL] enable additional
# features but are not required for the app to boot.
#
# SECURITY RULES:
#   • Variables prefixed NEXT_PUBLIC_ are baked into the client bundle.
#     Never put secrets in NEXT_PUBLIC_ variables.
#   • DATABASE_URL (pooled) is for runtime queries (Drizzle + RLS).
#   • DATABASE_URL_UNPOOLED (direct) is for migrations (drizzle-kit push/migrate).
#   • GOOGLE_AI_API_KEY and SUPABASE_SERVICE_ROLE_KEY must NEVER be exposed
#     to the browser.
# =============================================================================


# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and keys from: https://supabase.com/dashboard/project/_/settings/api

# [REQUIRED] Public API URL — safe for browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Anonymous key — safe for browser (RLS enforced)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# [REQUIRED] Service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ── Database ─────────────────────────────────────────────────────────────────
# From: https://supabase.com/dashboard/project/_/settings/database
# Use the "Transaction" pooler string (port 6543) for runtime (serverless).
# Use the "Direct" connection string (port 5432) for drizzle-kit migrations.

# [REQUIRED] Supabase Transaction Pooler — for runtime Drizzle queries on Vercel
# Format: postgresql://postgres.{ref}:{password}@aws-0-{region}.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# [REQUIRED] Direct connection — for drizzle-kit migrations (do NOT use on Vercel runtime)
# Format: postgresql://postgres:{password}@db.{ref}.supabase.co:5432/postgres
DATABASE_URL_UNPOOLED=postgresql://postgres:password@db.your-ref.supabase.co:5432/postgres


# ── Application ──────────────────────────────────────────────────────────────

# [REQUIRED] Root domain for multi-tenant subdomain routing
# Production example: toptenprom.com
# Local dev: localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=toptenprom.com

# [REQUIRED] Canonical app URL (used for metadataBase, OG images, canonical links)
# Production: https://www.toptenprom.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [REQUIRED] Corporate marketing subdomain (used by middleware to identify corporate requests)
# Production: www  (i.e., www.toptenprom.com serves the corporate site)
NEXT_PUBLIC_CORPORATE_DOMAIN=www

# [OPTIONAL] Maximum number of tenant boutiques the platform will activate
# Default: 55 (the franchise agreement ceiling)
TENANT_COUNT_MAX=55

# Set automatically by Vercel in preview and production deployments.
# Override locally only if testing NODE_ENV-gated logic.
NODE_ENV=development


# ── Google AI (Gemini) ────────────────────────────────────────────────────────
# From: https://aistudio.google.com/app/apikey
#
# CRITICAL: This key must NEVER be prefixed with NEXT_PUBLIC_.
# Used by: Gemini intent parsing in booking flow, virtual try-on Gemini Vision,
#          and AI analytics in the enterprise dashboard.

# [REQUIRED] Server-side only
GOOGLE_AI_API_KEY=your-gemini-api-key


# ── Google Maps Platform ──────────────────────────────────────────────────────
# From: https://console.cloud.google.com/ → APIs & Services → Credentials
# Required APIs to enable:
#   • Maps JavaScript API
#   • Maps Embed API (optional)
#   • Places API (for /locations search)
#
# Restrict this key to your production domain in the GCP console
# to prevent unauthorized usage.

# [REQUIRED] Enables interactive map on /network/locations
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key


# ── Expo / EAS (mobile-instore-app) ──────────────────────────────────────────
# These variables are consumed by the Expo app at build time via eas.json.
# They are NOT used by the Next.js apps.

# [REQUIRED for EAS builds] Base URL of the brand-network-web API
# Production: https://api.toptenprom.com  or  https://www.toptenprom.com
# Local dev: http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# [OPTIONAL] Supabase URL/anon key mirrored for the mobile app
# (same values as NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
